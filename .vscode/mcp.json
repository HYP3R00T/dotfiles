{
  "servers": {
    "mise": {
      "command": "mise",
      "args": [
        "mcp"
      ],
      "env": {
        "MISE_EXPERIMENTAL": "1"
      }
    },
    "ansible": {
      "command": "npx",
      "args": [
        "--yes",
        "@ansible/ansible-mcp-server",
        "--stdio"
      ]
    }
  }
}
